<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.frontend.EmployeeDashboard.EmployeeController">

<left>
    <VBox spacing="15.0" style="-fx-background-color: #830081; -fx-padding: 20;">
        <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-padding: 0 0 20 0;" text="Employee Dashboard" textFill="WHITE" />

        <Button prefHeight="40.0" prefWidth="220.0" style="-fx-font-size: 14px; -fx-background-color: #34495e; -fx-text-fill: white;" text="Ticket Sales" onAction="#showTicketSales"/>
        <Button text="Schedule" onAction="#showSchedule" prefHeight="40.0" prefWidth="220.0" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand;" />
        <Region VBox.vgrow="ALWAYS" />

        <Button prefHeight="40.0" prefWidth="220.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" text="Log out" onAction="#logout"/>
    </VBox>
</left>

<center>
    <BorderPane style="-fx-background-color: #ecf0f1;">
        <left>
            <VBox spacing="10">
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #830081;" text="Today's Screenings:" />
                <TableView fx:id="screeningTable" prefWidth="300.0" VBox.vgrow="ALWAYS" />
            </VBox>
        </left>

        <center>
            <VBox alignment="TOP_CENTER" spacing="10">
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #830081;" text="Seat Selection:" />
                <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <GridPane fx:id="seatGrid" alignment="CENTER" hgap="6.0" vgap="6.0">
                    </GridPane>
                </ScrollPane>
            </VBox>
        </center>


    </BorderPane>

        <StackPane fx:id="contentArea" style="-fx-background-color: #ecf0f1;">
            <Label text="Ładowanie modułu..." style="-fx-font-size: 24px; -fx-text-fill: #7f8c8d;"/>
        </StackPane>
    </center>
</BorderPane>