<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.frontend.EmployeeDashboard.EmployeeController">

<left>
    <VBox spacing="15.0" style="-fx-background-color: #830081; -fx-padding: 20;">
        <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-padding: 0 0 20 0;" text="Employee Dashboard" textFill="WHITE" />

        <Button prefHeight="40.0" prefWidth="220.0" style="-fx-font-size: 14px; -fx-background-color: #34495e; -fx-text-fill: white;" text="Ticket Sales" />

        <Region VBox.vgrow="ALWAYS" />

        <Button prefHeight="40.0" prefWidth="220.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" text="Log out" />
    </VBox>
</left>

<center>
    <BorderPane style="-fx-background-color: #ecf0f1;">
        <left>
            <VBox spacing="10">
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #830081;" text="Today's Screenings:" />
                <TableView fx:id="screeningTable" prefWidth="300.0" VBox.vgrow="ALWAYS" />
            </VBox>
        </left>

        <center>
            <VBox alignment="TOP_CENTER" spacing="10">
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #830081;" text="Seat Selection:" />
                <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <GridPane fx:id="seatGrid" alignment="CENTER" hgap="6.0" vgap="6.0">
                    </GridPane>
                </ScrollPane>
            </VBox>
        </center>

        <right>
            <VBox prefWidth="280.0" spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
                <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #830081;" text="Order Summary" />

                <Separator />

                <Label text="Selected screening:" textFill="#7f8c8d" />
                <Label fx:id="selectedMovieLabel" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #830081;" text="Select a Screening" wrapText="true" />

                <Separator />

                <Label text="Client Email(optional):" textFill="#7f8c8d" />
                <TextField fx:id="clientEmailField" prefHeight="35" promptText="np. myemail123@gmail.com" />

                <Region VBox.vgrow="ALWAYS" />

                <Label fx:id="totalPriceLabel" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" text="Total: 0.00 zł" />

                <Button fx:id="sellTicketBtn" prefHeight="45.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" text="Sell Tickets" />
            </VBox>
        </right>
    </BorderPane>

        <StackPane fx:id="contentArea" style="-fx-background-color: #ecf0f1;">
            <Label text="Ładowanie modułu..." style="-fx-font-size: 24px; -fx-text-fill: #7f8c8d;"/>
        </StackPane>
    </center>
</BorderPane>