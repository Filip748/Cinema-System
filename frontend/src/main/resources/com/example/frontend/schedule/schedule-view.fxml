<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.frontend.schedule.ScheduleViewController" style="-fx-background-color: #f4f4f4;">
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>

   <Label text="Add screen">
      <font>
         <Font size="16.0" />
      </font>
      <VBox.margin>
         <Insets bottom="20.0" />
      </VBox.margin>
   </Label>

   <VBox alignment="CENTER" maxWidth="350.0" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
      <padding>
         <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
      </padding>

      <VBox alignment="CENTER_LEFT" spacing="5.0">
         <Label text="Chose movie:" textFill="#555555" />
         <ComboBox fx:id="movieComboBox" promptText="Chose movie from database" maxWidth="Infinity" />
      </VBox>

      <HBox alignment="CENTER" spacing="10.0">
         <VBox alignment="CENTER_LEFT" spacing="5.0" HBox.hgrow="ALWAYS">
            <Label text="Data from:" textFill="#555555" />
            <DatePicker fx:id="startDatePicker" prefWidth="150.0" />
         </VBox>
         <VBox alignment="CENTER_LEFT" spacing="5.0" HBox.hgrow="ALWAYS">
            <Label text="Data to:" textFill="#555555" />
            <DatePicker fx:id="endDatePicker" prefWidth="150.0" />
         </VBox>
      </HBox>

      <VBox alignment="CENTER" spacing="5.0">
         <Label text="Time (format XX:YY):" textFill="#555555" />
         <TextField fx:id="timeField" promptText="e.g. 14:00" maxWidth="100.0" alignment="CENTER" />
      </VBox>

      <VBox alignment="CENTER_LEFT" spacing="5.0">
         <Label text="Chose a hall:" textFill="#555555" />
         <ComboBox fx:id="roomComboBox" promptText="Chose a hall" maxWidth="Infinity" />
      </VBox>

      <Label fx:id="messageLabel" text="Ready" textFill="GREEN">
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </Label>
   </VBox>

   <HBox alignment="CENTER" spacing="20.0">
      <VBox.margin>
         <Insets top="20.0" />
      </VBox.margin>
      <Button onAction="#handleSave" style="-fx-background-color: #4CAF50;" text="Save" textFill="WHITE">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
      </Button>
   </HBox>

</VBox>