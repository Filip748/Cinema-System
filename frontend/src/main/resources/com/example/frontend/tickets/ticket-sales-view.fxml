<?xml version="1.0" encoding="UTF-8"?>


<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720.0" prefWidth="1080.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.frontend.ticketSales.TicketSalesController">
    <left>
        <VBox spacing="10">
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="1. Select Screening:" />
            <TableView fx:id="screeningTable" prefWidth="350.0" VBox.vgrow="ALWAYS" />
        </VBox>
    </left>

    <center>
        <VBox alignment="TOP_CENTER" spacing="15">
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="3. Select Seats:" />

            <VBox alignment="CENTER" style="-fx-background-color: #bdc3c7; -fx-background-radius: 5; -fx-padding: 5;">
                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;" text="SCREEN" />
            </VBox>

            <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                <GridPane fx:id="seatGrid" alignment="CENTER" hgap="6.0" vgap="6.0">
                </GridPane>
            </ScrollPane>
        </VBox>
    </center>

    <right>
        <VBox prefWidth="320.0" spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
            <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Order Details" />

            <Separator />

            <Label fx:id="selectedMovieLabel" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #34495e;" text="Movie: Not selected" wrapText="true" />

            <Separator />

            <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="2. Select Tickets:" />

            <HBox alignment="CENTER_LEFT" spacing="10">
                <VBox HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-weight: bold;" text="Normal Ticket" />
                    <Label style="-fx-font-size: 12px;" textFill="#7f8c8d" text="25.00 PLN" />
                </VBox>
                <ComboBox fx:id="normalTicketComboBox" prefWidth="90.0" />
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <VBox HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-weight: bold;" text="Student Ticket" />
                    <Label style="-fx-font-size: 12px;" textFill="#7f8c8d" text="15.00 PLN" />
                </VBox>
                <ComboBox fx:id="studentTicketComboBox" prefWidth="90.0" />
            </HBox>

            <Separator />

            <Label text="Client Email (optional):" textFill="#7f8c8d" />
            <TextField fx:id="clientEmailField" prefHeight="35" promptText="e.g. email@domain.com" />

            <Region VBox.vgrow="ALWAYS" />

            <Label fx:id="seatsWarningLabel" style="-fx-text-fill: #e74c3c; -fx-font-weight: bold; -fx-font-size: 12px;" text="Select seats matching ticket count!" wrapText="true" visible="false" />

            <Label fx:id="totalPriceLabel" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" text="Total: 0.00 PLN" />

            <Button fx:id="sellTicketBtn" text="Sell Tickets" onAction="#handleSellTickets" />

        </VBox>
    </right>


</BorderPane>