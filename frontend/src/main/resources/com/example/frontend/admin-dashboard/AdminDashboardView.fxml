<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<BorderPane prefHeight="720.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.frontend.adminDashboard.AdminDashboardController">
    <left>
        <VBox spacing="15.0" style="-fx-background-color: #2c3e50; -fx-padding: 20;">
            <Label text="Admin Dashboard" textFill="WHITE" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-padding: 0 0 20 0;"/>

            <Button text="Schedule" onAction="#showSchedule" prefWidth="220.0" prefHeight="40.0" style="-fx-font-size: 14px;"/>
            <Button text="Add Movie" onAction="#openAddMovie" prefWidth="220.0" prefHeight="40.0" style="-fx-font-size: 14px;"/>
            <Button text="Add Screen" onAction="#openAddScreening" prefWidth="220.0" prefHeight="40.0" style="-fx-font-size: 14px;"/>
            <Button text="Add Hall" onAction="#openAddHall" prefWidth="220.0" prefHeight="40.0" style="-fx-font-size: 14px;"/>
            <Button text="Statistics" onAction="#showStatistics" prefWidth="220.0" prefHeight="40.0" style="-fx-font-size: 14px;"/>

            <Region VBox.vgrow="ALWAYS" />

            <Button text="Log out" onAction="#logout" prefWidth="220.0" prefHeight="40.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #ecf0f1;">
            <Label text="Ładowanie modułu..." style="-fx-font-size: 24px; -fx-text-fill: #7f8c8d;"/>
        </StackPane>
    </center>

</BorderPane>